# DeepSearch 环境变量配置示例
# 复制此文件为 .env 并填入您的 API 密钥

# ==================== LLM 配置 ====================
# Google Gemini API (推荐)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API (可选)
OPENAI_API_KEY=your_openai_api_key_here

# ==================== 搜索引擎配置 ====================
# 至少配置一个搜索引擎

# Google Custom Search (需要启用 Custom Search API)
GOOGLE_CX=your_google_custom_search_engine_id
# GOOGLE_API_KEY 已在上面配置

# Serper API (推荐，免费额度充足)
SERPER_API_KEY=your_serper_api_key_here

# SerpAPI (备选)
SERPAPI_API_KEY=your_serpapi_key_here

# Bing Search API (备选)
BING_API_KEY=your_bing_api_key_here

# ==================== ReAct 配置 ====================
# ReAct 功能开关
REACT_ENABLED=true

# ReAct 使用的模型 (LiteLLM 格式)
# 使用 Google AI Studio (推荐)
REACT_MODEL=gemini/gemini-2.0-flash-exp

# 或者使用其他模型
# REACT_MODEL=gpt-4
# REACT_MODEL=claude-3-5-sonnet

# ReAct 最大迭代次数
REACT_MAX_ITERATIONS=10

# 查询复杂度阈值 (0-1，超过此值使用 ReAct 模式)
REACT_COMPLEXITY_THRESHOLD=0.7

# ==================== 服务配置 ====================
# 服务端口
PORT=8000
HOST=0.0.0.0

# 调试模式
DEBUG=true

# ==================== 向量数据库配置 ====================
# ChromaDB 持久化路径
CHROMA_PERSIST_DIRECTORY=./data/chroma

# ==================== 日志配置 ====================
# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 日志文件路径
LOG_DIR=./logs

# 日志级别
LOG_LEVEL=INFO

# ==================== 获取 API 密钥的链接 ====================
# Google Gemini API: https://ai.google.dev/
# OpenAI API: https://platform.openai.com/api-keys
# Serper API: https://serper.dev/
# SerpAPI: https://serpapi.com/
# Google Custom Search: https://developers.google.com/custom-search/v1/introduction
# Bing Search API: https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
